{
    "name": "flockwatch-react",
    "private": true,
    "version": "0.1.9",
    "type": "module",
    "scripts": {
        "dev": "vite --host",
        "build": "tsc -b && vite build",
        "test": "vitest",
        "test:unit": "vitest tests/unit",
        "test:coverage": "vitest run --coverage",
        "lint": "tsc -b && eslint . --fix",
        "preview": "vite preview",
        "docs": "typedoc",
        "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|tsx|json)\""
    },
    "dependencies": {
        "@tanstack/query-persist-client-core": "5.101.2",
        "@tanstack/query-sync-storage-persister": "5.101.2",
        "@tanstack/react-query": "5.101.2",
        "@upstash/redis": "^1.38.0",
        "d3": "^7.9.0",
        "d3-geo": "^3.1.1",
        "react": "^19.2.7",
        "react-dom": "^19.1.0",
        "topojson-client": "^3.1.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@tanstack/eslint-plugin-query": "5.101.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/d3": "^7.4.3",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@types/topojson-client": "^3.1.5",
        "@types/topojson-specification": "^1.0.5",
        "@vitejs/plugin-react-swc": "^4.3.1",
        "@vitest/coverage-v8": "^4.1.9",
        "eslint": "^10.5.0",
        "eslint-plugin-a11y": "^1.0.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.3",
        "globals": "^17.6.0",
        "jsdom": "^29.1.1",
        "nock": "^14.0.16",
        "node-fetch": "^3.3.2",
        "prettier": "3.8.4",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.63.0",
        "vite": "^8.1.3",
        "vitest": "^4.1.9"
    }
}
